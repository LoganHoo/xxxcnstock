# XCNStock 股票分析系统配置
# 复制此文件为 .env 并填入实际配置

# ==================== 应用配置 ====================
APP_NAME=XCNStock
APP_VERSION=0.1.0
DEBUG=false

# ==================== 服务端口 ====================
GATEWAY_PORT=8000
DATA_SERVICE_PORT=8001
STOCK_SERVICE_PORT=8002
LIMIT_SERVICE_PORT=8003
NOTIFY_SERVICE_PORT=8004

# ==================== 数据路径 ====================
DATA_DIR=data
LOG_DIR=logs

# ==================== 微信通知 (Server酱) ====================
# 注册地址: https://sct.ftqq.com/
WECHAT_SEND_KEY=

# ==================== 钉钉机器人 ====================
# 创建机器人后获取 webhook 和 secret
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# ==================== 邮件通知 ====================
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_RECIPIENTS=

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== 调度配置 ====================
SCHEDULE_ENABLED=true

# ==================== MySQL配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=quantdb
DB_CHARSET=utf8mb4
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600
