# XCNStock 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 数据源配置 ====================

# Tushare Pro Token
TUSHARE_TOKEN=your_tushare_token_here

# Baostock (无需token，但可配置其他参数)
BAOSTOCK_TIMEOUT=30

# ==================== 数据库配置 ====================

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=xcnstock
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=xcnstock

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== 性能优化配置 ====================

# 并行数据采集配置
PARALLEL_MAX_CONCURRENT=50
PARALLEL_BATCH_SIZE=100
PARALLEL_CALLS_PER_MINUTE=480
PARALLEL_REQUEST_TIMEOUT=30

# 缓存配置
CACHE_L1_MAXSIZE=1000
CACHE_L1_TTL=3600
CACHE_L2_TTL=86400

# Polars 配置
POLARS_MAX_THREADS=
POLARS_STREAMING=false

# ==================== 监控配置 ====================

# Prometheus 配置
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# 告警 Webhook (可选)
ALERT_WEBHOOK_URL=

# ==================== 调度器配置 ====================

# Kestra 配置
KESTRA_API_URL=http://localhost:8082/api/v1
KESTRA_NAMESPACE=xcnstock

# 双调度器配置
SCHEDULER_PRIMARY=kestra
SCHEDULER_FAILOVER_ENABLED=true

# ==================== 数据目录配置 ====================

DATA_DIR=/app/data
LOG_DIR=/app/logs
CACHE_DIR=/app/cache

# ==================== 安全配置 ====================

# API 安全
API_SECRET_KEY=your_secret_key_here
API_ACCESS_TOKEN=your_access_token_here

# ==================== 其他配置 ====================

# 时区
TZ=Asia/Shanghai

# Python 配置
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
